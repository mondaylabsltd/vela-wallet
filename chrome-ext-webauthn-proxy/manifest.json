{
  "manifest_version": 3,
  "name": "Vela WebAuthn Dev Proxy",
  "version": "1.3.2",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "description": "Proxy WebAuthn calls to use a production rpId (default getvela.app, configurable) on any dev/preview domain",
  "permissions": ["storage"],
  "host_permissions": [
    "*://getvela.app/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png"
    },
    "default_title": "Vela WebAuthn Proxy — settings"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://localhost:*/*",
        "http://127.0.0.1/*",
        "http://127.0.0.1:*/*",
        "https://*.pages.dev/*",
        "https://*.workers.dev/*",
        "https://*.github.io/*",
        "https://*.vercel.app/*",
        "https://*.netlify.app/*",
        "https://*.deno.dev/*",
        "https://*.fly.dev/*",
        "https://*.railway.app/*",
        "https://*.render.com/*",
        "https://*.surge.sh/*",
        "https://*.ngrok-free.app/*",
        "https://*.trycloudflare.com/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "http://localhost/*",
        "http://localhost:*/*",
        "http://127.0.0.1/*",
        "http://127.0.0.1:*/*",
        "https://*.pages.dev/*",
        "https://*.workers.dev/*",
        "https://*.github.io/*",
        "https://*.vercel.app/*",
        "https://*.netlify.app/*",
        "https://*.deno.dev/*",
        "https://*.fly.dev/*",
        "https://*.railway.app/*",
        "https://*.render.com/*",
        "https://*.surge.sh/*",
        "https://*.ngrok-free.app/*",
        "https://*.trycloudflare.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ]
}
