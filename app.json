{
  "expo": {
    "name": "Vela Wallet",
    "slug": "vela-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "velawallet",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "app.getvela.VelaWallet",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Vela Wallet uses Bluetooth to securely connect with the Vela Connect browser extension.",
        "NSBluetoothPeripheralUsageDescription": "Vela Wallet uses Bluetooth to securely connect with the Vela Connect browser extension.",
        "NSCameraUsageDescription": "Vela Wallet uses the camera to scan QR codes for wallet addresses.",
        "UIBackgroundModes": [
          "bluetooth-peripheral"
        ]
      }
    },
    "android": {
      "package": "app.getvela.wallet",
      "adaptiveIcon": {
        "backgroundColor": "#0A1929",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_ADVERTISE",
        "BLUETOOTH_CONNECT",
        "CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Inter-Regular.ttf",
            "./assets/fonts/Inter-Medium.ttf",
            "./assets/fonts/Inter-SemiBold.ttf",
            "./assets/fonts/Inter-Bold.ttf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A1A18",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180
        }
      ],
      "./plugins/with-native-modules",
      "expo-sharing",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-media-library",
        {
          "photosPermission": "Vela Wallet saves your receive QR code to your photo library.",
          "savePhotosPermission": "Vela Wallet saves your receive QR code to your photo library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
