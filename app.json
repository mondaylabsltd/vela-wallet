{
  "expo": {
    "name": "Vela Wallet",
    "slug": "vela-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "velawallet",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/0d798810-2982-455b-9079-7b9a7cabb97d"
    },
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "app.getvela.VelaWallet",
      "infoPlist": {
        "NSCameraUsageDescription": "Vela Wallet uses the camera to scan QR codes for wallet addresses.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.getvela.wallet",
      "allowBackup": false,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#0A1929",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Inter-Regular.ttf",
            "./assets/fonts/Inter-Medium.ttf",
            "./assets/fonts/Inter-SemiBold.ttf",
            "./assets/fonts/Inter-Bold.ttf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A1A18",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180
        }
      ],
      "expo-sharing",
      [
        "expo-camera",
        {
          "recordAudioAndroid": false
        }
      ],
      "expo-image-picker",
      [
        "expo-media-library",
        {
          "photosPermission": "Vela Wallet saves your receive QR code to your photo library.",
          "savePhotosPermission": "Vela Wallet saves your receive QR code to your photo library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-localization",
      "./plugins/with-native-modules",
      "./plugins/with-release-signing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "0d798810-2982-455b-9079-7b9a7cabb97d"
      }
    },
    "owner": "monday-labs-ltd"
  }
}
