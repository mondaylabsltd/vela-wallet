# Release upload-keystore config — copy to android/keystore.properties (gitignored).
#
# Create the keystore once (keep it OUT of the repo, back it up somewhere safe):
#   keytool -genkeypair -v -keystore upload-keystore.jks -alias vela-upload \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Then enroll in Play App Signing and put BOTH cert SHA-256 fingerprints
# (upload cert + Play's app-signing cert) into
# getvela.app/src/routes/.well-known/assetlinks.json — passkeys break otherwise.
# Full steps: docs/NATIVE-LAUNCH-CHECKLIST.md section A1.
storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=vela-upload
keyPassword=CHANGE_ME
